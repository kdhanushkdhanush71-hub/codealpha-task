  lemmatizer = WordNetLemmatizer()
stop_words  = set(stopwords.words("english"))

def preprocess(text: str) -> str:
    """Lowercase → tokenize → remove punctuation & stopwords → lemmatize."""
    text   = text.lower()
    tokens = word_tokenize(text)
    tokens = [
        lemmatizer.lemmatize(t)
        for t in tokens
        if t not in stop_words and t not in string.punctuation
    ]
    return " ".join(tokens)

# Preprocess all FAQ questions
processed_questions = [preprocess(q) for q in questions]
vectorizer    = TfidfVectorizer()
faq_vectors   = vectorizer.fit_transform(processed_questions)
THRESHOLD = 0.15   # minimum similarity score to give an answer

def get_response(user_input: str):
    """
    Preprocess user input → vectorize → cosine similarity →
    return best matching answer (or fallback message).
    """
    cleaned    = preprocess(user_input)
    user_vec   = vectorizer.transform([cleaned])
    scores     = cosine_similarity(user_vec, faq_vectors).flatten()
    best_idx   = int(np.argmax(scores))
    best_score = scores[best_idx]

    if best_score >= THRESHOLD:
        matched_q  = questions[best_idx]
        answer     = answers[best_idx]
        confidence = round(best_score * 100, 1)
        return answer, matched_q, confidence
    else:
        return None, None, 0.0
